<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Contato | Dash Brasil</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="./contact.css">
</head>
<body>
  <main class="contact-page">
    <section class="contact-hero section-animate">
      <div class="contact-hero__inner">
        <a href="sobrenos.html" class="brand-mark" aria-label="Dash Brasil">


        </a>
        <p class="eyebrow">Contato</p>
        <h1>Vamos conversar sobre o seu projeto.</h1>
        <p class="contact-hero__sub">
          Fale com nossa equipe para tirar d&uacute;vidas, solicitar um or&ccedil;amento ou iniciar uma nova solu&ccedil;&atilde;o digital.
        </p>
      </div>
    </section>

    <section class="contact-body">
      <aside class="channels section-animate">
        <p class="channels__title">Canais diretos</p>

        <a href="mailto:dashbrasilds@gmail.com" class="channel-card" aria-label="Enviar e-mail">
          <div class="channel-card__icon channel-card__icon--email">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="M2 7l10 7 10-7"/></svg>
          </div>
          <div class="channel-card__info">
            <span class="channel-card__label">E-mail</span>
            <span class="channel-card__value">dashbrasilds@gmail.com</span>
          </div>
          <svg class="channel-card__arrow" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M7 17L17 7"/><path d="M7 7h10v10"/></svg>
        </a>

        <a href="https://wa.me/5515999999999" target="_blank" rel="noopener" class="channel-card" aria-label="Falar no WhatsApp">
          <div class="channel-card__icon channel-card__icon--whatsapp">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"/></svg>
          </div>
          <div class="channel-card__info">
            <span class="channel-card__label">WhatsApp</span>
            <span class="channel-card__value">(15) 9 9999-9999</span>
          </div>
          <svg class="channel-card__arrow" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M7 17L17 7"/><path d="M7 7h10v10"/></svg>
        </a>

        <a href="https://instagram.com/dashbrasil" target="_blank" rel="noopener" class="channel-card" aria-label="Ver Instagram">
          <div class="channel-card__icon channel-card__icon--instagram">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="2" y="2" width="20" height="20" rx="5"/><circle cx="12" cy="12" r="4"/><circle cx="17.5" cy="6.5" r="0.8" fill="currentColor" stroke="none"/></svg>
          </div>
          <div class="channel-card__info">
            <span class="channel-card__label">Instagram</span>
            <span class="channel-card__value">@dashbrasil</span>
          </div>
          <svg class="channel-card__arrow" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M7 17L17 7"/><path d="M7 7h10v10"/></svg>
        </a>


        </div>
      </aside>

      <section class="form-wrap section-animate">
        <p class="form-wrap__title">Envie uma mensagem</p>
        <form class="contact-form" id="contactForm" novalidate>
          <div class="form-row form-row--split">
            <div class="form-group">
              <label for="name">Nome</label>
              <input type="text" id="name" name="name" placeholder="Seu nome" required autocomplete="name">
            </div>
            <div class="form-group">
              <label for="email">E-mail</label>
              <input type="email" id="email" name="email" placeholder="seu@email.com" required autocomplete="email">
            </div>
          </div>

          <div class="form-group">
            <label for="subject">Assunto</label>
            <select id="subject" name="subject" required>
              <option value="" disabled selected>Selecione um assunto</option>
              <option value="projeto">Novo projeto</option>
              <option value="orcamento">Or&ccedil;amento</option>
              <option value="suporte">Suporte</option>
              <option value="parceria">Parceria</option>
              <option value="outro">Outro</option>
            </select>
          </div>

          <div class="form-group">
            <label for="message">Mensagem</label>
            <textarea id="message" name="message" rows="5" placeholder="Descreva brevemente o que voc&ecirc; precisa..." required></textarea>
          </div>

          <button type="submit" class="form-submit" id="submitBtn">
            <span id="btnText">Enviar mensagem</span>
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="22" y1="2" x2="11" y2="13"/><polygon points="22 2 15 22 11 13 2 9 22 2"/></svg>
          </button>

          <p class="form-note" id="formNote" aria-live="polite"></p>
        </form>
      </section>
    </section>
  </main>



  <script src="./contato.js"></script>
</body>
</html>
